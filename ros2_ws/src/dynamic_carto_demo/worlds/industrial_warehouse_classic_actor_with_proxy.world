<?xml version="1.0"?>
<!--

  Route A world (recommended for Cartographer dynamic filtering experiments):
    - Full industrial warehouse scene (same as industrial_warehouse_classic.world)
    - Animated walking actor (legs move)
    - Invisible collision proxy follows actor (LiDAR / collision sees it)

  Prerequisite (required):
    git clone https://github.com/aws-robotics/aws-robomaker-small-warehouse-world.git
    export GAZEBO_MODEL_PATH=~/third_party/aws-robomaker-small-warehouse-world/models:$GAZEBO_MODEL_PATH

  Also required:
    export GAZEBO_MODEL_PATH=/home/yican/newdisk/projects/Dynamic-Carto-SLAM/ros2_ws/src/dynamic_carto_demo/models:$GAZEBO_MODEL_PATH
    export GAZEBO_PLUGIN_PATH=/home/yican/newdisk/projects/Dynamic-Carto-SLAM/ros2_ws/install/lib:$GAZEBO_PLUGIN_PATH

-->
<sdf version="1.6">
  <world name="industrial_warehouse_classic_actor_with_proxy">

    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
        <remapping>model_states:=model_states</remapping>
      </ros>
      <update_rate>50.0</update_rate>
    </plugin>

    <!-- Match official TB3 worlds: use model://ground_plane as the only floor. -->
    <include>
      <uri>model://ground_plane</uri>
    </include>
    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <shadows>true</shadows>
    </scene>

    <gui fullscreen="0">
      <camera name="user_camera">
        <pose frame="">0 0 14 0 1.20 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <!-- Match official turtlebot3_world/house physics (ODE solver + contact params). -->
    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>
    
    <gravity>0 0 -9.8</gravity>

    <!-- Warehouse floor: visual mesh only (texture), collision handled by model://ground_plane. -->
    <model name="aws_robomaker_warehouse_GroundB_01_visual_only">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://aws_robomaker_warehouse_GroundB_01/meshes/aws_robomaker_warehouse_GroundB_01_visual.DAE</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
      <pose>0.0 0.0 -0.090092 0 0 0</pose>
    </model>

