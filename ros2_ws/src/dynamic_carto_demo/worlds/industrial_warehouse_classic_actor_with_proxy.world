    <!-- Make proxy follow actor -->
    <plugin name="actor_proxy_follower" filename="libactor_proxy_follower.so">
      <actor_name>walking_actor_01</actor_name>
      <proxy_name>walking_person_proxy_01</proxy_name>
      <!-- actor pose already has a Z origin near body center; don't add extra lift -->
      <!-- shift proxy down so 2D lidar plane intersects the cylinder -->
      <z_offset>-0.15</z_offset>
    </plugin>

    <!-- walking_actor_02: …40s (2.5,-3.7); hold→100s teleport (-4.4,-3.6); 170–175 march; 175.05→z=-5 then 176–300 slow→z=-10 -->
